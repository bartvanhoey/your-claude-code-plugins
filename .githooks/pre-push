#!/bin/sh
# Pulls the latest changes for the current remote before allowing a push.
# Git resolves what to push *before* invoking this hook and won't re-check
# after it returns, so a clean merge here can't make the in-flight push
# succeed - it would still get rejected by the remote with a confusing
# generic error. Instead, always abort after a pull changes the branch (or
# fails outright) and ask for a clean re-run, which picks up the merge.

remote="$1"

before=$(git rev-parse HEAD)

if ! git pull "$remote"; then
    echo "pre-push: 'git pull' failed. Resolve the issue, then push again." >&2
    exit 1
fi

after=$(git rev-parse HEAD)

if [ "$before" != "$after" ]; then
    echo "pre-push: pulled new commits from '$remote'. Re-run 'git push' to push the updated branch." >&2
    exit 1
fi

exit 0
