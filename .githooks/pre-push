#!/bin/sh
# Pulls the latest changes for the current remote before allowing a push,
# so the push always goes out against an up-to-date branch. Only aborts if
# the pull itself fails (e.g. merge conflicts); a clean pull/merge is
# allowed to continue so the push includes the newly merged commits.

remote="$1"

before=$(git rev-parse HEAD)

if ! git pull "$remote"; then
    echo "pre-push: 'git pull' failed. Resolve the issue, then push again." >&2
    exit 1
fi

after=$(git rev-parse HEAD)

if [ "$before" != "$after" ]; then
    echo "pre-push: pulled new commits from '$remote' before pushing." >&2
fi

exit 0
