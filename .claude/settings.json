{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/configure-git-hooks-path.sh",
            "statusMessage": "Configuring git hooks path..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/git-push-pull-check.sh",
            "statusMessage": "Checking for upstream changes before push..."
          }
        ]
      }
    ]
  }
}
